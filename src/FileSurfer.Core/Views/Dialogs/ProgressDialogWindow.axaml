<Window x:Class="FileSurfer.Core.Views.Dialogs.ProgressDialogWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Width="560"
        Height="230"
        d:DesignHeight="230"
        d:DesignWidth="560"
        CanResize="False"
        Classes="DialogWindow"
        ShowInTaskbar="True"
        mc:Ignorable="d">

    <Window.Styles>
        <StyleInclude Source="avares://FileSurfer.Core/Views/Dialogs/DialogWindowStyle.axaml" />
    </Window.Styles>

    <!--  ReSharper disable Xaml.BindingWithoutContextNotResolved  -->
    <Grid Classes="MainGrid" RowDefinitions="* 45">
        <Border Classes="InfoBlockBorder">
            <StackPanel Margin="20 0 20 0" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <TextBlock FontSize="11" Foreground="{DynamicResource TextColor}" Text="{Binding CurrentItem}" TextTrimming="LeadingCharacterEllipsis" />
                <ProgressBar Height="20"
                             IsIndeterminate="{Binding IsIndeterminate}"
                             Maximum="1"
                             Minimum="0"
                             Value="{Binding Fraction}" />
            </StackPanel>
        </Border>

        <Rectangle Grid.Row="1" Classes="BottomRectangle" />
        <Button Grid.Row="1" Classes="BottomButton" Click="OnCancelClicked" Content="Cancel" />
    </Grid>

</Window>
